# ─────────────────────────────────────────────────────────
# NexusOps — variáveis de ambiente para Docker Compose
# Copiar para .env e preencher antes de correr `docker compose up`
# NÃO commitar o .env com valores reais
# ─────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────
POSTGRES_DB=nexusops
POSTGRES_USER=nexusops
POSTGRES_PASSWORD=ALTERAR_ESTA_PASSWORD

# ── Aplicação ─────────────────────────────────────────────
# Em produção, gerar com: openssl rand -hex 32
JWT_SECRET=ALTERAR_ESTE_SECRET_MINIMO_32_CARACTERES

# ── Notas ─────────────────────────────────────────────────
# Credenciais IMAP e Wisedat são geridas via UI (Dashboard Config)
# e guardadas na tabela system_config da BD. Não definir aqui.
